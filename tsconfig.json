{
  "compilerOptions": {
    "target": "esnext",
    "module": "esnext",
    "moduleResolution": "bundler",
    "lib": ["esnext", "es2021", "DOM", "DOM.Iterable"],
    "types": ["mocha"],
    "noEmit": true,
    "strict": true,
    // WARNING: Avoid enabling the `skipLibCheck` option as it disables type checking
    // for the components' type declarations (e.g packages/button/src/vaadin-button.d.ts).
    "skipLibCheck": false,
    "skipDefaultLibCheck": true,
    "allowImportingTsExtensions": true,
    "allowSyntheticDefaultImports": true,
    "allowJs": true
  },
  "include": [
    "packages/**/test",
    "test",
    "packages/icon/src",
    "packages/details/src",
    "packages/a11y-base/src",
    "packages/field-base/src"
  ]
}
